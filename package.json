{
  "name": "path.ux",
  "version": "0.1.26",
  "description": "Html5 based UI library with blender-rna-style data binding",
  "main": "dist/pathux.js",
  "browser": "true",
  "scripts": {
    "build": "node buildtools/esbuild.mjs",
    "watch": "node buildtools/esbuild.mjs --watch",
    "typecheck": "npx tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"scripts/**/*.{ts,js}\"",
    "format:check": "prettier --check \"scripts/**/*.{ts,js}\"",
    "build-docs": "bash build_docs.sh",
    "render-icons": "bash render_icons.sh",
    "markdown-toc": "bash run_markdown_toc.sh",
    "serv": "node serv.js"
  },
  "directories": {
    "doc": "docs"
  },
  "type": "module",
  "devDependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@pathtx/prettier": "3.3.0-dev",
    "@types/parse5": "^7.0.0",
    "diff": "^5.2.2",
    "electron": "^41.1.1",
    "esbuild": "^0.28.0",
    "esdoc": "^1.1.0",
    "esdoc-ecmascript-proposal-plugin": "^1.0.0",
    "esdoc-standard-plugin": "^1.0.0",
    "markdown-toc": "^1.2.0",
    "marked": "^12.0.2",
    "minimist": "^1.2.8",
    "parse5": "6.0.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joeedh/path.ux.git"
  },
  "author": "Joseph Eagar",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/joeedh/path.ux/issues"
  },
  "homepage": "https://github.com/joeedh/path.ux#readme",
  "packageManager": "pnpm@10.30.3"
}
